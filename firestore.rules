rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerifiedUser() && request.auth.token.email == 'boxputt@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (data.keys().hasAny(['role']) ? data.role in ['user', 'admin'] : true);
    }
    
    match /users/{userId} {
      allow get: if isVerifiedUser() && request.auth.uid == userId;
      // allow read, update: if isVerifiedUser() && request.auth.uid == userId;
      allow create: if isVerifiedUser() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerifiedUser() && request.auth.uid == userId && 
                       isValidUser(incoming()) && 
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       (!incoming().keys().hasAny(['role']) || existing().role == incoming().role || isAdmin());
    }

    // --- Watch History ---
    match /users/{userId}/watchHistory/{historyId} {
      allow read: if isVerifiedUser() && request.auth.uid == userId;
      allow create: if isVerifiedUser() && request.auth.uid == userId &&
                       incoming().keys().hasAll(['userId', 'animeId', 'episodeId', 'watchedAt']) &&
                       incoming().userId == request.auth.uid &&
                       incoming().watchedAt is timestamp;
      allow update: if isVerifiedUser() && request.auth.uid == userId &&
                       incoming().keys().hasAll(['userId', 'animeId', 'episodeId', 'watchedAt']) &&
                       incoming().userId == existing().userId &&
                       incoming().animeId == existing().animeId &&
                       incoming().episodeId == existing().episodeId &&
                       incoming().watchedAt is timestamp;
      allow delete: if isVerifiedUser() && request.auth.uid == userId;
    }

    // --- Favorites ---
    match /users/{userId}/favorites/{favId} {
      allow read: if isVerifiedUser() && request.auth.uid == userId;
      allow create: if isVerifiedUser() && request.auth.uid == userId &&
                       incoming().keys().hasAll(['userId', 'animeId', 'createdAt']) &&
                       incoming().userId == request.auth.uid &&
                       incoming().createdAt is timestamp;
      allow delete: if isVerifiedUser() && request.auth.uid == userId;
    }

    // --- Public Read, Admin Write ---
    match /anime/{animeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
